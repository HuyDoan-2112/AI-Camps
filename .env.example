AWS_REGION=us-west-2
BEDROCK_KB_ID=replace-with-managed-kb-id
# Optional override; agentcore/config.json pins the tested default.
BEDROCK_MODEL_ID=

# Filled by infra/deploy_agentcore.py after deployment.
AGENTCORE_HARNESS_ARN=replace-with-agentcore-harness-arn
AGENTCORE_HARNESS_ENDPOINT=DEFAULT

# Optional only when reusing IAM roles instead of --bootstrap-iam.
AGENTCORE_HARNESS_ROLE_ARN=
AGENTCORE_GATEWAY_ROLE_ARN=
ADVISOR_TOOLS_LAMBDA_ROLE_ARN=
